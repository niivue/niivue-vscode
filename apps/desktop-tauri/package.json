{
  "name": "@niivue/tauri",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NiiVue Tauri - standalone medical image viewer built with Tauri",
  "license": "BSD-2-Clause",
  "author": {
    "name": "Korbinian Eckstein",
    "email": "korbinian90@gmail.com"
  },
  "homepage": "https://github.com/niivue/niivue-vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/niivue/niivue-vscode.git",
    "directory": "apps/desktop-tauri"
  },
  "bugs": {
    "url": "https://github.com/niivue/niivue-vscode/issues"
  },
  "keywords": [
    "tauri",
    "desktop",
    "niivue",
    "neuroimaging",
    "medical-imaging",
    "nifti",
    "dicom",
    "visualization"
  ],
  "scripts": {
    "dev:frontend": "vite --port 4001",
    "build:frontend": "vite build",
    "dev": "tauri dev",
    "build": "vite build",
    "build:bundle": "tauri build",
    "clean": "rimraf build src-tauri/target",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier --write src/**/*.{ts,tsx,css,md}",
    "format:check": "prettier --check src/**/*.{ts,tsx,css,md}",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@niivue/dicom-loader": "^1.0.0",
    "@niivue/niivue": "^0.68.2",
    "@niivue/react": "workspace:*",
    "@preact/signals": "^2.9.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-store": "^2.4.0",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@niivue/dcm2niix": "^1.2.0",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.14",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-virtual": "^0.4.0",
    "vitest": "^4.1.6"
  }
}
