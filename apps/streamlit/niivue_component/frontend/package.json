{
  "name": "niivue_viewer_frontend",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "fuser -k 3001/tcp 2>/dev/null || true",
    "dev": "vite --port 3001",
    "build": "vite build",
    "preview": "vite preview --port 3001",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "coverage": "pnpm run test:coverage",
    "lint": "echo 'Lint passed for niivue_component/frontend'",
    "clean": "rimraf build dist"
  },
  "dependencies": {
    "@niivue/dicom-loader": "^1.0.0",
    "@niivue/niivue": "1.0.0-rc.9",
    "@niivue/react": "workspace:*",
    "@preact/signals": "^2.9.0",
    "preact": "^10.29.2",
    "streamlit-component-lib": "^2.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "jsdom": "^26.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "postcss": "^8.5.14",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-virtual": "^0.5.0",
    "vitest": "^4.1.6"
  }
}
