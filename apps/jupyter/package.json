{
  "name": "@niivue/jupyter",
  "private": true,
  "version": "0.2.7",
  "description": "A JupyterLab extension for viewing NIfTI files with Niivue",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "niivue",
    "nifti",
    "neuroimaging"
  ],
  "homepage": "https://github.com/niivue/niivue-vscode/tree/main/apps/jupyter",
  "bugs": {
    "url": "https://github.com/niivue/niivue-vscode/issues"
  },
  "license": "BSD-2-Clause",
  "author": {
    "name": "Korbinian Eckstein",
    "email": "korbinian90@gmail.com"
  },
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,js,eot,gif,html,jpg,json,png,svg,woff2,ttf}",
    "schema/*.json",
    "static/**/*"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/niivue/niivue-vscode.git",
    "directory": "apps/jupyter"
  },
  "scripts": {
    "build": "pnpm run build:assets && pnpm run build:lib && pnpm run build:labextension:dev",
    "build:prod": "pnpm run clean && pnpm run build:assets && pnpm run build:lib:prod && pnpm run build:labextension",
    "build:assets": "node build-assets.mjs",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "clean": "rimraf lib tsconfig.tsbuildinfo .tsbuildinfo .webpack-cache jupyterlab_niivue/labextension jupyterlab_niivue/_version.py .eslintcache .stylelintcache static/niivue build *.egg-info",
    "clean:all": "pnpm run clean && rimraf dist",
    "dev": "run-p watch:lib watch:labextension",
    "watch": "pnpm run dev",
    "watch:lib": "tsc -w --sourceMap --preserveWatchOutput",
    "watch:labextension": "jupyter labextension watch . --development=True",
    "lint": "pnpm run lint:eslint && pnpm run lint:prettier && pnpm run lint:style",
    "lint:fix": "pnpm run lint:eslint --fix && pnpm run lint:prettier --write && pnpm run lint:style --fix",
    "lint:eslint": "eslint . --cache --ext .ts,.tsx",
    "lint:prettier": "prettier \"**/*.{ts,tsx,js,jsx,css,json,md}\" --check",
    "lint:style": "stylelint --cache \"style/**/*.css\"",
    "format": "prettier \"**/*.{ts,tsx,js,jsx,css,json,md}\" --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage": "pnpm run test:coverage",
    "release:test": "pnpm run clean:all && pnpm run build:prod && python -m build --wheel && python -m twine upload --repository testpypi dist/*",
    "release:prod": "pnpm run clean:all && pnpm run build:prod && python -m build --wheel && python -m twine upload dist/*",
    "release:check": "pnpm run clean:all && pnpm run build:prod && python -m build --wheel && python -m twine check dist/*"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.5.7",
    "@jupyterlab/apputils": "^4.6.7",
    "@jupyterlab/coreutils": "^6.5.7",
    "@jupyterlab/docmanager": "^4.5.7",
    "@jupyterlab/docregistry": "^4.5.7",
    "@jupyterlab/filebrowser": "^4.5.7",
    "@jupyterlab/fileeditor": "^4.5.7",
    "@jupyterlab/services": "^7.5.7",
    "@jupyterlab/translation": "^4.5.7",
    "@lumino/widgets": "^2.7.5",
    "@niivue/niivue": "^0.68.2"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.5.7",
    "@niivue/dicom-loader": "^1.0.0",
    "@niivue/react": "workspace:*",
    "@preact/signals": "^2.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint-plugin-prettier": "^5.5.5",
    "mkdirp": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "preact": "^10.29.2",
    "rimraf": "^6.1.3",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "stylelint": "^17.11.1",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-csstree-validator": "^4.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "yjs": "^13.6.30"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "styleModule": "style/index.js",
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlab_niivue/labextension",
    "schemaDir": "schema",
    "webpackConfig": "./webpack.config.js"
  }
}
